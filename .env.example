# ─── Database ────────────────────────────────────────────────────────────────
# A local Postgres. No Docker anywhere in this project — dev, CI and production all
# talk to a real Postgres process (locally installed; in production, on the box itself).
#   createuser -P vellum && createdb -O vellum vellum && createdb -O vellum vellum_test
DATABASE_URL="postgresql://vellum:vellum@localhost:5432/vellum?schema=public"
TEST_DATABASE_URL="postgresql://vellum:vellum@localhost:5432/vellum_test?schema=public"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=debug

# Origins allowed to call the API and open a WebSocket. Comma separated.
# Never set to "*": credentials are sent on these requests.
CORS_ORIGINS="http://localhost:3000"  # comma-separated; E2E also needs http://127.0.0.1:3100

# ─── Auth ────────────────────────────────────────────────────────────────────
# Auth.js runs in the frontend and owns the user session. It mints a short-lived
# HS256 access token for this API, signed with the secret below. Both services
# must share it, and it must never reach the browser.
# Generate: openssl rand -base64 48
API_JWT_SECRET="dev-only-insecure-secret-replace-me-with-openssl-rand-base64-48"
API_JWT_ISSUER="vellum-web"
API_JWT_AUDIENCE="vellum-api"

# Service-to-service secret. The frontend's Auth.js callbacks use this to create
# and look up user records (the frontend has no database access of its own).
# Generate: openssl rand -base64 48
SERVICE_TOKEN="dev-only-insecure-service-token-replace-me"

# ─── AI ──────────────────────────────────────────────────────────────────────
# The API key lives here and only here. It is never shipped to the browser.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-opus-4-8"

# ─── Limits (see ARCHITECTURE.md §10) ────────────────────────────────────────
MAX_REQUEST_BYTES=1048576
RATE_LIMIT_REQUESTS_PER_MINUTE=120
RATE_LIMIT_OPS_PER_MINUTE=600
RATE_LIMIT_AI_PER_HOUR=60
