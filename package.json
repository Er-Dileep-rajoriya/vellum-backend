{
  "name": "vellum-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Vellum sync + collaboration server. An ordered, idempotent operation log.",
  "type": "module",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "node dist/main.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate": "prisma generate",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "lint:fix": "eslint . --fix",
    "smoke": "tsx scripts/smoke.ts",
    "smoke:auth": "tsx scripts/auth-smoke.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@fastify/cors": "^11.3.0",
    "@fastify/helmet": "^13.1.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.10.0",
    "jose": "^6.2.3",
    "pg": "^8.22.0",
    "pino": "^9.14.0",
    "ulid": "^3.0.2",
    "ws": "^8.21.0",
    "zod": "^4.4.3",
    "prisma": "^7.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "eslint": "^9.39.5",
    "pino-pretty": "^13.1.3",
    "tsc-alias": "^1.9.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
